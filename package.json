{
  "name": "web-vitals-inspector",
  "version": "1.0.0",
  "description": "Web Vitals Inspector",
  "main": "./out/main/index.js",
  "author": "Web Vitals Inspector",
  "homepage": "https://github.com/web-vitals-inspector/web-vitals-inspector",
  "scripts": {
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "cross-env NODE_OPTIONS=\"--max-old-space-size=16384 --expose-gc\" electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "stress:mock-site": "node scripts/stress/mock-site.mjs",
    "stress:prepare-urls": "node scripts/stress/generate-urls.mjs",
    "stress:prepare-urls:1200": "node scripts/stress/generate-urls.mjs --count=1200",
    "stress:analyzer": "npm run build && cross-env NODE_OPTIONS=\"--max-old-space-size=16384 --expose-gc\" electron . --stress-test",
    "stress:analyzer:resume": "npm run build && cross-env NODE_OPTIONS=\"--max-old-space-size=16384 --expose-gc\" electron . --stress-test --resume"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "axios": "^1.16.0",
    "exceljs": "^4.4.0",
    "lighthouse": "^13.1.0",
    "puppeteer": "^24.40.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
